# Project Settings
PROJECT_NAME=adhoc
PROJECT_LOG_LEVEL=INFO

# Azure Blob Storage Settings
AZURE_BLOB_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net
AZURE_BLOB_STORAGE_CONTAINER_NAME=adhoc

# Microsoft Foundry Settings
MICROSOFT_FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>

# BYOK Settings
BYOK_PROVIDER_TYPE=openai
BYOK_BASE_URL=https://<your-resource>.openai.azure.com/openai/v1/
BYOK_API_KEY=<your-api-key>
BYOK_MODEL=gpt-5
BYOK_WIRE_API=responses
