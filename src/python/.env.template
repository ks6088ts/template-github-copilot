# ---------
# Project environment variables
# ---------

# Project Settings
PROJECT_NAME=adhoc
PROJECT_LOG_LEVEL=INFO

# Azure Blob Storage Settings
AZURE_BLOB_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net
AZURE_BLOB_STORAGE_CONTAINER_NAME=adhoc

# Microsoft Foundry Settings
MICROSOFT_FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>

# BYOK Settings
BYOK_PROVIDER_TYPE=openai
BYOK_BASE_URL=https://<your-resource>.openai.azure.com/openai/v1/
BYOK_API_KEY=<your-api-key>
BYOK_MODEL=gpt-5
BYOK_WIRE_API=responses

# OAuth GitHub App Settings
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=<your-github-oauth-client-id>
GITHUB_CLIENT_SECRET=<your-github-oauth-client-secret>
SESSION_SECRET=<random-secret-for-cookie-signing>
API_HOST=127.0.0.1
API_PORT=8000
# Set to the Copilot CLI server URL (e.g. localhost:3000 for local, copilot:3000 for Docker Compose).
# Leave empty to let the SDK spawn its own Copilot CLI subprocess.
COPILOT_CLI_URL=

# Timeout in seconds for Copilot SDK send_and_wait calls (default: 300)
COPILOT_SEND_TIMEOUT=300

# ---------
# OpenTelemetry (optional) — enables tracing for the tutorial scripts.
# Start the stack first: docker compose -f docker/compose.yaml up -d
# ---------

# OTLP HTTP endpoint of the local collector. Leave empty to disable telemetry.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Set to true to capture prompt/response content in spans.
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=false
# Span batch flush interval (ms). The SDK SIGKILLs the CLI after a single-shot
# prompt, so the default 5000ms loses spans — keep this low (e.g. 500) so the
# CLI flushes before it is terminated.
OTEL_BSP_SCHEDULE_DELAY=500

# ---------
# Copilot / Docker Compose Settings
# ---------

# GitHub PAT with Copilot scope (required for Copilot CLI server and Docker Compose)
COPILOT_GITHUB_TOKEN=<your-copilot-github-token>

# Model used by the Copilot CLI server (used in Makefile and Docker Compose)
COPILOT_MODEL=gpt-5-mini
